# Supabase (https://supabase.com — projeto novo dedicado à barbearia)
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Auth
AUTH_SECRET="gerar-com-openssl-rand-base64-32"
AUTH_COOKIE_NAME="barbearia_session"

# WhatsApp UaZapi (fallback global — cada org pode ter seu próprio token em organizations.whatsapp_instancia_token)
UAZAPI_BASE_URL="https://uazapi.dev-manager-01..."
UAZAPI_TOKEN=""

# Cron lembretes WhatsApp (header Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# TZ é reservada no Vercel — não configurar lá. Código fixa America/Sao_Paulo.
TZ="America/Sao_Paulo"
